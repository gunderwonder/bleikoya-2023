<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/12.5/phpunit.xsd" bootstrap="tests/bootstrap.php" colors="true">
  <testsuites>
    <testsuite name="Unit">
      <directory suffix="Test.php">tests/unit</directory>
    </testsuite>
    <testsuite name="Integration">
      <directory suffix="Test.php">tests/integration</directory>
    </testsuite>
    <testsuite name="HealthCheck">
      <directory suffix="Test.php">tests/health</directory>
    </testsuite>
  </testsuites>
  <source>
    <include>
      <directory suffix=".php">includes</directory>
    </include>
    <exclude>
      <directory>vendor</directory>
    </exclude>
  </source>
</phpunit>
